        "liquid": "{% assign blog_search_id = section.id | default: 'custom-liquid-blog-search' %}\n\n<style>\n  .blog-search-{{ blog_search_id }} {\n    width: 100%;\n    max-width: 100%;\n  }\n\n  .blog-search-form-{{ blog_search_id }} {\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    margin-bottom: 50px;\n  }\n\n  .blog-search-input-wrapper-{{ blog_search_id }} {\n    flex-grow: 1;\n    max-width: 700px;\n  }\n\n  .blog-search-input-{{ blog_search_id }} {\n    width: 100%;\n    padding: 12px 18px;\n    border: 1px solid #cccccc;\n    border-radius: 6px;\n    background-color: #ffffff;\n    color: #282828;\n    font-size: 16px;\n  }\n\n  .blog-search-input-{{ blog_search_id }}::placeholder {\n    color: #999999;\n  }\n\n  .blog-search-input-{{ blog_search_id }}:focus {\n    outline: none;\n    border-color: #405de6;\n  }\n\n  .blog-search-button-{{ blog_search_id }} {\n    padding: 12px 24px;\n    background-color: #405de6;\n    color: #ffffff;\n    border: none;\n    border-radius: 6px;\n    font-size: 16px;\n    font-weight: 600;\n    cursor: pointer;\n    white-space: nowrap;\n  }\n\n  .blog-search-button-{{ blog_search_id }}:hover {\n    background-color: #282828;\n  }\n\n  @media screen and (max-width: 749px) {\n    .blog-search-form-{{ blog_search_id }} {\n      flex-direction: column;\n    }\n\n    .blog-search-button-{{ blog_search_id }} {\n      width: 100%;\n      max-width: 700px;\n    }\n  }\n</style>\n\n<div class=\"blog-search-{{ blog_search_id }}\">\n  <form action=\"/search\" method=\"get\" class=\"blog-search-form-{{ blog_search_id }}\" role=\"search\">\n    <input type=\"hidden\" name=\"type\" value=\"article\">\n\n    <div class=\"blog-search-input-wrapper-{{ blog_search_id }}\">\n      <input\n        type=\"search\"\n        name=\"q\"\n        class=\"blog-search-input-{{ blog_search_id }}\"\n        placeholder=\"Search blog posts\"\n        value=\"{{ search.terms | escape }}