{% schema %}
    {
      "name": "Full Width Image Banner",
      "tag": "section",
      "class": "section section-full-width-image-banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop background image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile background image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "DXQ SERIES"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "SQ/AUDIOPHILE"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Woofer features a high quality yellow straw and composite foam cone with a durable rubber surround, for excellent bass response and improved heat dissipation for reliability during intense use.</p><p>Complementing this is a 1-inch silk dome tweeter with a neodymium magnet, delivering smooth, high frequency sounds that enhance every note.</p>"
        },
        {
          "type": "range",
          "id": "banner_height",
          "label": "Banner height",
          "min": 300,
          "max": 800,
          "step": 10,
          "default": 460,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "banner_height_mobile",
          "label": "Mobile banner height",
          "min": 220,
          "max": 600,
          "step": 10,
          "default": 300,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "content_max_width",
          "label": "Content max width",
          "min": 800,
          "max": 1520,
          "step": 20,
          "default": 1520,
          "unit": "px"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content horizontal position",
          "default": "right",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text align",
          "default": "left",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "type": "checkbox",
          "id": "enable_overlay",
          "label": "Enable overlay",
          "default": true
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "default": 20,
          "unit": "%"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "subheading_color",
          "label": "Subheading color",
          "default": "#d9d9d9"
        },
        {
          "type": "color",
          "id": "description_color",
          "label": "Description color",
          "default": "#f2f2f2"
        },
        {
          "type": "range",
          "id": "side_padding",
          "label": "Side padding",
          "min": 16,
          "max": 80,
          "step": 4,
          "default": 32,
          "unit": "px"
        }
      ],
      "presets": [
        {
          "name": "Full Width Image Banner"
        }
      ]
    }
{% endschema %}
    
    {% liquid
      assign overlay_alpha = section.settings.overlay_opacity | times: 0.01
    %}
    
    <section
      id="Banner-{{ section.id }}"
      class="custom-image-banner custom-image-banner--{{ section.settings.content_position }} custom-image-banner--text-{{ section.settings.text_align }}"
      style="
        --banner-height: {{ section.settings.banner_height }}px;
        --banner-height-mobile: {{ section.settings.banner_height_mobile }}px;
        --content-max-width: {{ section.settings.content_max_width }}px;
        --side-padding: {{ section.settings.side_padding }}px;
        --heading-color: {{ section.settings.heading_color }};
        --subheading-color: {{ section.settings.subheading_color }};
        --description-color: {{ section.settings.description_color }};
        --overlay-color: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
      "
    >
      <div class="custom-image-banner__media">
        {% if section.settings.desktop_image != blank %}
          <picture>
            {% if section.settings.mobile_image != blank %}
              <source
                media="(max-width: 749px)"
                srcset="
                  {{ section.settings.mobile_image | image_url: width: 750 }} 750w,
                  {{ section.settings.mobile_image | image_url: width: 1100 }} 1100w
                "
              >
            {% endif %}
            {{
              section.settings.desktop_image
              | image_url: width: 2400
              | image_tag:
                widths: '900, 1200, 1600, 2000, 2400',
                loading: 'lazy',
                class: 'custom-image-banner__image',
                alt: section.settings.heading
            }}
          </picture>
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'custom-image-banner__image custom-image-banner__image--placeholder' }}
        {% endif %}
    
        {% if section.settings.enable_overlay %}
          <div class="custom-image-banner__overlay"></div>
        {% endif %}
      </div>
    
      <div class="custom-image-banner__content-wrap">
        <div class="custom-image-banner__content-inner">
          <div class="custom-image-banner__content">
            {% if section.settings.heading != blank %}
              <h1 class="custom-image-banner__heading">
                {{ section.settings.heading }}
              </h1>
            {% endif %}
    
            {% if section.settings.subheading != blank %}
              <h2 class="custom-image-banner__subheading">
                {{ section.settings.subheading }}
              </h2>
            {% endif %}
    
            {% if section.settings.description != blank %}
              <div class="custom-image-banner__description rte">
                {{ section.settings.description }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </section>
    
    <style>
      #Banner-{{ section.id }} {
        position: relative;
        width: 100%;
        min-height: var(--banner-height);
        overflow: hidden;
        background: #111;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__media,
      #Banner-{{ section.id }} .custom-image-banner__overlay,
      #Banner-{{ section.id }} .custom-image-banner__content-wrap {
        position: absolute;
        inset: 0;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__image,
      #Banner-{{ section.id }} .custom-image-banner__image--placeholder {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__overlay {
        background: var(--overlay-color);
        z-index: 1;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__content-wrap {
        z-index: 2;
        display: flex;
        align-items: center;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__content-inner {
        width: 100%;
        max-width: var(--content-max-width);
        margin: 0 auto;
        padding-left: var(--side-padding);
        padding-right: var(--side-padding);
        display: flex;
      }
    
      #Banner-{{ section.id }}.custom-image-banner--left .custom-image-banner__content-inner {
        justify-content: flex-start;
      }
    
      #Banner-{{ section.id }}.custom-image-banner--center .custom-image-banner__content-inner {
        justify-content: center;
      }
    
      #Banner-{{ section.id }}.custom-image-banner--right .custom-image-banner__content-inner {
        justify-content: flex-end;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__content {
        max-width: 520px;
      }
    
      #Banner-{{ section.id }}.custom-image-banner--text-left .custom-image-banner__content {
        text-align: left;
      }
    
      #Banner-{{ section.id }}.custom-image-banner--text-center .custom-image-banner__content {
        text-align: center;
      }
    
      #Banner-{{ section.id }}.custom-image-banner--text-right .custom-image-banner__content {
        text-align: right;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__heading {
        margin: 0 0 6px;
        color: var(--heading-color);
        font-size: clamp(20px, 4vw, 35px);
        line-height: 1;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__subheading {
        margin: 0 0 18px;
        color: var(--subheading-color);
        font-size: clamp(16px, 1.6vw, 20px);
        line-height: 1.1;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      #Banner-{{ section.id }} .custom-image-banner__description {
        width: 75%;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__description,
      #Banner-{{ section.id }} .custom-image-banner__description p {
        color: var(--description-color);
        font-size: 14px;
        line-height: 1.6;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__description p {
        margin: 0 0 12px;
      }
    
      #Banner-{{ section.id }} .custom-image-banner__description p:last-child {
        margin-bottom: 0;
      }
    
      @media screen and (max-width: 749px) {
        #Banner-{{ section.id }} {
          min-height: var(--banner-height-mobile);
        }
    
        #Banner-{{ section.id }} .custom-image-banner__content-inner {
          justify-content: center;
        }
    
        #Banner-{{ section.id }} .custom-image-banner__content {
          max-width: 100%;
          text-align: center;
        }
    
        #Banner-{{ section.id }} .custom-image-banner__heading {
          font-size: 30px;
        }
    
        #Banner-{{ section.id }} .custom-image-banner__subheading {
          font-size: 16px;
        }
    
        #Banner-{{ section.id }} .custom-image-banner__description,
        #Banner-{{ section.id }} .custom-image-banner__description p {
          font-size: 13px;
        }
      }
    </style>