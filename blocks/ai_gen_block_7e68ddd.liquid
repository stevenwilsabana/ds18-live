{% doc %}
  @prompt
    create vertical space at least 30px
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: {{ block.settings.spacing_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.spacing_mobile }}px;
    }
  }
{% endstyle %}

<spacer-block-{{ ai_gen_id }}
  class="ai-spacer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
></spacer-block-{{ ai_gen_id }}>

<script>
  (function() {
    class SpacerBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('spacer-block-{{ ai_gen_id }}', SpacerBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Vertical spacer",
  "settings": [
    {
      "type": "range",
      "id": "spacing_desktop",
      "label": "Desktop spacing",
      "min": 30,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "label": "Mobile spacing",
      "min": 20,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Vertical spacer"
    }
  ]
}
{% endschema %}
